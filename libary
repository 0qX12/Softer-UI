			ValCorner.Parent = ValBtn
			
			local VStroke = Instance.new("UIStroke")
			AddTheme(VStroke, "Color", "Border")
			VStroke.Parent = ValBtn

			local ListContainer = Instance.new("Frame")
			ListContainer.Size = UDim2.new(1, -30, 0, 0)
			ListContainer.Position = UDim2.new(0, 15, 0, 50)
			AddTheme(ListContainer, "BackgroundColor3", "Bg")
			ListContainer.Parent = El
			
			local ListCorner = Instance.new("UICorner")
			ListCorner.CornerRadius = UDim.new(0, 6)
			ListCorner.Parent = ListContainer
			
			local ListLayout = Instance.new("UIListLayout")
			ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
			ListLayout.Parent = ListContainer

			local Obj = {Value = selected}
			function Obj:SetValue(val)
				self.Value = val
				ValBtn.Text = tostring(val)
				isOpened = false
				TweenService:Create(El, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 45)}):Play()
				if callback then callback(val) end
			end
			
			if flag then Library.Flags[flag] = Obj end

			local function BuildOptions(newOptions)
				for _, v in pairs(ListContainer:GetChildren()) do 
					if v:IsA("TextButton") then v:Destroy() end 
				end
				options = newOptions
				for _, opt in ipairs(options) do
					local OptBtn = Instance.new("TextButton")
					OptBtn.Size = UDim2.new(1, 0, 0, 28)
					OptBtn.BackgroundTransparency = 1
					OptBtn.Text = "  " .. tostring(opt)
					OptBtn.Font = Enum.Font.Gotham
					AddTheme(OptBtn, "TextColor3", "Muted")
					OptBtn.TextSize = 12
					OptBtn.TextXAlignment = Enum.TextXAlignment.Left
					OptBtn.Parent = ListContainer

					OptBtn.MouseButton1Click:Connect(function()
						Obj:SetValue(opt)
					end)
				end
			end
			BuildOptions(options)

			ValBtn.MouseButton1Click:Connect(function()
				isOpened = not isOpened
				local newHeight = isOpened and (45 + 10 + (#options * 28)) or 45
				TweenService:Create(El, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, newHeight)}):Play()
				ListContainer.Size = UDim2.new(1, -30, 0, #options * 28)
			end)

			function Obj:Refresh(newOptions)
				BuildOptions(newOptions)
				if not table.find(newOptions, self.Value) then 
					self:SetValue(newOptions[1] or "") 
				end
				if isOpened then
					TweenService:Create(El, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 45 + 10 + (#newOptions * 28))}):Play()
					ListContainer.Size = UDim2.new(1, -30, 0, #newOptions * 28)
				end
			end
			
			return Obj
		end

