local CurrentTheme = "Dark"
local ThemeObjects = {}
local ThemeTweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local RequiredThemeKeys = {"Bg", "CardBg", "Sidebar", "Border", "Text", "Muted", "Inactive", "Accent"}

local function ResolveThemeColor(themeName, colorRole)
	local theme = Themes[themeName]
	if not theme then
		return nil
	end
	return theme[colorRole]
end

local function CleanupThemeObjects()
	for i = #ThemeObjects, 1, -1 do
		local obj = ThemeObjects[i]
		if obj.Removed or not obj.Inst or not obj.Inst.Parent then
			table.remove(ThemeObjects, i)
		end
	end
end

local function AddTheme(instance, property, colorRole)
	if not instance or not property or not colorRole then
		return nil
	end

	local binding = {
		Inst = instance,
		Prop = property,
		Role = colorRole,
		Removed = false
	}
	table.insert(ThemeObjects, binding)

	local color = ResolveThemeColor(CurrentTheme, colorRole)
	if color then
		instance[property] = color
	end

	pcall(function()
		instance.Destroying:Connect(function()
			binding.Removed = true
		end)
	end)

	return binding
end

local function SetThemeRole(binding, colorRole)
	if not binding or not colorRole then
		return
	end

	binding.Role = colorRole

	local inst = binding.Inst
	if inst and inst.Parent then
		local color = ResolveThemeColor(CurrentTheme, colorRole)
		if color then
			inst[binding.Prop] = color
		end
	end
end

Library.UpdateTheme = function(themeName)
	if type(themeName) ~= "string" or not Themes[themeName] then
		return false
	end

	CurrentTheme = themeName
	local theme = Themes[themeName]
	CleanupThemeObjects()

	for i = #ThemeObjects, 1, -1 do
		local obj = ThemeObjects[i]
		local targetColor = theme[obj.Role]
		if obj.Inst and obj.Inst.Parent and targetColor then
			local ok, currentColor = pcall(function()
				return obj.Inst[obj.Prop]
			end)

			if ok and currentColor ~= targetColor then
				TweenService:Create(obj.Inst, ThemeTweenInfo, {
					[obj.Prop] = targetColor
				}):Play()
			end
		else
			table.remove(ThemeObjects, i)
		end
	end

	return true
end

Library.GetThemeNames = function()
	local names = {}
	for themeName in pairs(Themes) do
		table.insert(names, themeName)
	end

	table.sort(names, function(a, b)
		if a == "Dark" then
			return true
		elseif b == "Dark" then
			return false
		end
		return a < b
	end)

	return names
end

Library.GetCurrentTheme = function()
	return CurrentTheme
end

Library.RegisterTheme = function(themeName, themeData)
	if type(themeName) ~= "string" or themeName == "" or type(themeData) ~= "table" then
		return false
	end

	for _, key in ipairs(RequiredThemeKeys) do
		if typeof(themeData[key]) ~= "Color3" then
			return false
		end
	end

	Themes[themeName] = themeData
	return true
end

Library.Themes = Themes

