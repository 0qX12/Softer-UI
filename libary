local CurrentTheme = "Dark"
local ThemeObjects = {} 

local function AddTheme(instance, property, colorRole)
	table.insert(ThemeObjects, {Inst = instance, Prop = property, Role = colorRole})
	instance[property] = Themes[CurrentTheme][colorRole]
end

Library.UpdateTheme = function(themeName)
	if not Themes[themeName] then return end
	CurrentTheme = themeName
	local t = Themes[themeName]
	
	for i = #ThemeObjects, 1, -1 do
		local obj = ThemeObjects[i]
		if obj.Inst and obj.Inst.Parent then
			local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
			TweenService:Create(obj.Inst, tweenInfo, {
				[obj.Prop] = t[obj.Role]
			}):Play()
		else
			table.remove(ThemeObjects, i)
		end
	end
end

-- === СИСТЕМА КОНФИГОВ (JSON) ===
local ConfigFolder = "DY_configs"
local IsStudio = RunService:IsStudio() or not writefile
local StudioMockFiles = {}

if not IsStudio then
	if not isfolder(ConfigFolder) then 
		makefolder(ConfigFolder) 
	end
end

Library.GetSavedConfigs = function()
	local list = {}
	if IsStudio then
		for name, _ in pairs(StudioMockFiles) do 
			table.insert(list, name) 
		end
	else
		for _, file in ipairs(listfiles(ConfigFolder)) do
			local name = file:match("([^/\\]+)%.txt$") or file:match("([^/\\]+)$")
			if name then 
				table.insert(list, name) 
			end
		end
	end
	if #list == 0 then 
		table.insert(list, "Default") 
	end
	return list
end

Library.SaveConfig = function(name)
	local data = {}
	for flag, obj in pairs(Library.Flags) do
		if typeof(obj.Value) == "EnumItem" then
			data[flag] = "ENUM_" .. obj.Value.Name
		else
			data[flag] = obj.Value
		end
	end
	
	local json = HttpService:JSONEncode(data)
	
	if IsStudio then
		StudioMockFiles[name] = json
	else
		writefile(ConfigFolder .. "/" .. name .. ".txt", json)
	end
end

Library.LoadConfig = function(name)
	local json = ""
	if IsStudio then
		json = StudioMockFiles[name] or ""
	else
		local path = ConfigFolder .. "/" .. name .. ".txt"
		if isfile(path) then 
			json = readfile(path) 
		end
	end
	
	if json == "" then return end
	
	local success, data = pcall(function() 
		return HttpService:JSONDecode(json) 
	end)
	
	if success and type(data) == "table" then
		for flag, value in pairs(data) do
			if Library.Flags[flag] then
				if type(value) == "string" and string.sub(value, 1, 5) == "ENUM_" then
					local keyName = string.sub(value, 6)
					pcall(function() 
						Library.Flags[flag]:SetValue(Enum.KeyCode[keyName]) 
					end)
				else
					pcall(function() 
						Library.Flags[flag]:SetValue(value) 
					end)
				end
			end
		end
	end
end

Library.DeleteFile = function(name)
	if IsStudio then
		StudioMockFiles[name] = nil
	else
		local path = ConfigFolder .. "/" .. name .. ".txt"
		if isfile(path) then 
			delfile(path) 
		end
	end
end

