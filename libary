		-- ЭЛЕМЕНТ: ПОЛЗУНОК (SLIDER)
		function TabLib:AddSlider(EConfig)
			local text = EConfig.Title or "Slider"
			local min = EConfig.Min or 0
			local max = EConfig.Max or 100
			local value = EConfig.Default or min
			local flag = EConfig.Flag
			local callback = EConfig.Callback
			
			local El = CreateElementWrapper(55)

			local TitleLbl = Instance.new("TextLabel")
			TitleLbl.Size = UDim2.new(1, -60, 0, 25)
			TitleLbl.Position = UDim2.new(0, 15, 0, 5)
			TitleLbl.BackgroundTransparency = 1
			TitleLbl.Text = text
			TitleLbl.Font = Enum.Font.GothamMedium
			AddTheme(TitleLbl, "TextColor3", "Muted")
			TitleLbl.TextSize = 13
			TitleLbl.TextXAlignment = Enum.TextXAlignment.Left
			TitleLbl.Parent = El

			local ValLbl = Instance.new("TextLabel")
			ValLbl.Size = UDim2.new(0, 40, 0, 25)
			ValLbl.Position = UDim2.new(1, -55, 0, 5)
			ValLbl.BackgroundTransparency = 1
			ValLbl.Text = tostring(value)
			ValLbl.Font = Enum.Font.GothamBold
			AddTheme(ValLbl, "TextColor3", "Text")
			ValLbl.TextSize = 13
			ValLbl.TextXAlignment = Enum.TextXAlignment.Right
			ValLbl.Parent = El

			local Track = Instance.new("TextButton")
			Track.Size = UDim2.new(1, -30, 0, 6)
			Track.Position = UDim2.new(0, 15, 1, -15)
			AddTheme(Track, "BackgroundColor3", "Inactive")
			Track.AutoButtonColor = false
			Track.Text = ""
			Track.Parent = El
			
			local TrackCorner = Instance.new("UICorner")
			TrackCorner.CornerRadius = UDim.new(1, 0)
			TrackCorner.Parent = Track

			local Fill = Instance.new("Frame")
			local pct = (value - min) / (max - min)
			if pct ~= pct then pct = 0 end
			Fill.Size = UDim2.new(pct, 0, 1, 0)
			AddTheme(Fill, "BackgroundColor3", "Accent")
			Fill.BorderSizePixel = 0
			Fill.Parent = Track
			
			local FillCorner = Instance.new("UICorner")
			FillCorner.CornerRadius = UDim.new(1, 0)
			FillCorner.Parent = Fill

			local Obj = {Value = value}
			function Obj:SetValue(val)
				val = math.clamp(val, min, max)
				self.Value = val
				ValLbl.Text = tostring(val)
				local newPct = (val - min) / (max - min)
				TweenService:Create(Fill, TweenInfo.new(0.1), {Size = UDim2.new(newPct, 0, 1, 0)}):Play()
				if callback then callback(val) end
			end
			
			if flag then Library.Flags[flag] = Obj end

			local dragging = false
			local function update(input) 
				local p = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
				local newVal = math.floor(min + (max - min) * p)
				Obj:SetValue(newVal) 
			end
			
			Track.InputBegan:Connect(function(input) 
				if input.UserInputType == Enum.UserInputType.MouseButton1 then 
					dragging = true
					update(input) 
				end 
			end)
			UserInputService.InputChanged:Connect(function(input) 
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then 
					update(input) 
				end 
			end)
			UserInputService.InputEnded:Connect(function(input) 
				if input.UserInputType == Enum.UserInputType.MouseButton1 then 
					dragging = false 
				end 
			end)
			
			return Obj
		end

		-- ЭЛЕМЕНТ: ВЫПАДАЮЩИЙ СПИСОК (DROPDOWN)
		function TabLib:AddDropdown(EConfig)
			local text = EConfig.Title or "Dropdown"
