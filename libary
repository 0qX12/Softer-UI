				function CardLib:AddSlider(EConfig)
					EConfig = NormalizeElementConfig(EConfig, "Slider")
					local text = EConfig.Title or "Slider"
					local min = tonumber(EConfig.Min) or 0
					local max = tonumber(EConfig.Max) or 100
					if min > max then
						min, max = max, min
					end

					local precision = math.max(0, math.floor(tonumber(EConfig.Precision) or 0))
					local factor = 10 ^ precision
					local range = max - min
					if range <= 0 then
						range = 1
					end

					local function Quantize(val)
						if precision == 0 then
							return math.floor(val + 0.5)
						end
						return math.floor(val * factor + 0.5) / factor
					end

					local function FormatValue(val)
						if precision == 0 then
							return tostring(math.floor(val + 0.5))
						end
						return string.format("%." .. precision .. "f", val)
					end

					local value = tonumber(EConfig.Default)
					if value == nil then
						value = min
					end
					value = math.clamp(Quantize(value), min, max)
					local flag = EConfig.Flag
					local callback = EConfig.Callback
					
					local SliderFrame = Instance.new("Frame")
					SliderFrame.Size = UDim2.new(1, 0, 0, 46)
				SliderFrame.BackgroundTransparency = 1
				SliderFrame.Parent = ItemContainer

				local Label = Instance.new("TextLabel")
