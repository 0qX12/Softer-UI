					local IconTheme = AddTheme(Icon, "TextColor3", "Muted")
					Icon.TextSize = 12
					Icon.ZIndex = 22
					Icon.Parent = TopBtn

					local ListContainer = Instance.new("ScrollingFrame")
					ListContainer.Size = UDim2.new(1, 0, 0, dropdownMaxHeight)
					ListContainer.Position = UDim2.new(0, 0, 0, 38)
					AddTheme(ListContainer, "BackgroundColor3", "Bg")
					AddTheme(ListContainer, "ScrollBarImageColor3", "Border")
					ListContainer.BorderSizePixel = 0
					ListContainer.Active = true
					ListContainer.ScrollingEnabled = true
					ListContainer.ScrollBarThickness = 4
					ListContainer.ScrollBarImageTransparency = 0.35
					ListContainer.BackgroundTransparency = 0.03
					ListContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
					ListContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
					ListContainer.ZIndex = 23
					ListContainer.Parent = DropFrame

					local ListCorner = Instance.new("UICorner")
					ListCorner.CornerRadius = UDim.new(0, 6)
					ListCorner.Parent = ListContainer

					local ListStroke = Instance.new("UIStroke")
					AddTheme(ListStroke, "Color", "Border")
					ListStroke.Transparency = 0.8
					ListStroke.Parent = ListContainer

					local ListPadding = Instance.new("UIPadding")
					ListPadding.PaddingTop = UDim.new(0, 4)
					ListPadding.PaddingBottom = UDim.new(0, 4)
					ListPadding.PaddingLeft = UDim.new(0, 4)
					ListPadding.PaddingRight = UDim.new(0, 4)
					ListPadding.Parent = ListContainer

					local ListLayout = Instance.new("UIListLayout")
					ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
					ListLayout.Padding = UDim.new(0, 4)
					ListLayout.Parent = ListContainer

					local OptionButtons = {}
					local SelectedSet = {}

					local function CopyArray(values)
						local out = {}
						for i, value in ipairs(values) do
							out[i] = value
						end
						return out
					end

					local function CollectSelectedArray()
						local values = {}
						for _, opt in ipairs(options) do
							if SelectedSet[opt] then
								table.insert(values, opt)
							end
						end
						return values
					end

					local function GetStatusText()
						if not isMulti then
							return tostring(Obj.Value)
						end

						local labels = {}
						for _, opt in ipairs(options) do
							if SelectedSet[opt] then
								table.insert(labels, tostring(opt))
							end
						end

						if #labels == 0 then
							return "None"
						end
						if #labels <= 2 then
							return table.concat(labels, ", ")
						end
						return string.format("%d selected", #labels)
					end

					local function IsOptionSelected(opt)
						if isMulti then
							return SelectedSet[opt] == true
						end
						return Obj.Value == opt
					end

					local function UpdateTopVisual()
						local bgTransparency
						local strokeTransparency
						if isOpened then
							bgTransparency = 0
							strokeTransparency = 0.45
						elseif isHoveringTop then
							bgTransparency = 0.12
							strokeTransparency = 0.6
						else
							bgTransparency = 0.05
							strokeTransparency = 0.75
						end

						TweenService:Create(TopBtn, TweenInfo.new(0.12), {BackgroundTransparency = bgTransparency}):Play()
						TweenService:Create(DStroke, TweenInfo.new(0.12), {Transparency = strokeTransparency}):Play()
						TweenService:Create(Icon, TweenInfo.new(0.18), {Rotation = isOpened and 180 or 0}):Play()
						SetThemeRole(IconTheme, isOpened and "Text" or "Muted")
					end

					local function UpdateOptionButton(opt, optionData)
						if not optionData or not optionData.Btn then
							return
						end

						local button = optionData.Btn
						local label = optionData.Label
						local selectedState = IsOptionSelected(opt)
						local hovered = optionData.Hovered

						if label then
							label.Text = tostring(opt)
						end

						if selectedState then
							if label then
								label.Font = Enum.Font.GothamBold
							end
							SetThemeRole(optionData.TextTheme, "Text")
							SetThemeRole(optionData.BgTheme, "Inactive")
							SetThemeRole(optionData.IndicatorTheme, "Inactive")
							button.BackgroundTransparency = 0.3
							optionData.Indicator.BackgroundTransparency = 0.15
							optionData.IndicatorStroke.Transparency = 0.45
							optionData.IndicatorFill.Visible = true
						elseif hovered then
							if label then
								label.Font = Enum.Font.Gotham
							end
							SetThemeRole(optionData.TextTheme, "Text")
							SetThemeRole(optionData.BgTheme, "Inactive")
							SetThemeRole(optionData.IndicatorTheme, "Inactive")
							button.BackgroundTransparency = 0.84
							optionData.Indicator.BackgroundTransparency = 0.35
							optionData.IndicatorStroke.Transparency = 0.62
							optionData.IndicatorFill.Visible = false
						else
							if label then
								label.Font = Enum.Font.Gotham
							end
							SetThemeRole(optionData.TextTheme, "Muted")
							SetThemeRole(optionData.BgTheme, "Inactive")
							SetThemeRole(optionData.IndicatorTheme, "Inactive")
							button.BackgroundTransparency = 1
							optionData.Indicator.BackgroundTransparency = 0.5
							optionData.IndicatorStroke.Transparency = 0.72
							optionData.IndicatorFill.Visible = false
						end
					end

					local function SyncVisualState()
						Status.Text = GetStatusText()
						for opt, optionData in pairs(OptionButtons) do
							UpdateOptionButton(opt, optionData)
						end
						UpdateTopVisual()
					end

					if isMulti then
						for _, value in ipairs(selected) do
							if table.find(options, value) then
								SelectedSet[value] = true
							end
						end
						Obj.Value = CollectSelectedArray()
					end

					function Obj:SetValue(val)
						if isMulti then
							SelectedSet = {}
							if type(val) == "table" then
								for _, item in ipairs(val) do
									if table.find(options, item) then
										SelectedSet[item] = true
									end
								end
							elseif val ~= nil and val ~= "" and table.find(options, val) then
								SelectedSet[val] = true
							end

							self.Value = CollectSelectedArray()
							SyncVisualState()
							ListContainer.CanvasPosition = Vector2.new(0, 0)
							if callback then
								callback(CopyArray(self.Value))
							end
							return
						end

						self.Value = val
						SyncVisualState()
						isOpened = false
						TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 34)}):Play()
						ListContainer.CanvasPosition = Vector2.new(0, 0)
						if callback then
							callback(val)
						end
					end

					if flag then
						Library.Flags[flag] = Obj
					end

					local function BuildOptions(newOptions)
						newOptions = type(newOptions) == "table" and newOptions or {}
						for _, child in ipairs(ListContainer:GetChildren()) do
							if child:IsA("TextButton") then
								child:Destroy()
							end
						end
						OptionButtons = {}

						options = newOptions
							for _, opt in ipairs(options) do
								local OptBtn = Instance.new("TextButton")
								OptBtn.Size = UDim2.new(1, 0, 0, optionHeight)
								OptBtn.BackgroundTransparency = 1
								OptBtn.Text = ""
								OptBtn.AutoButtonColor = false
								OptBtn.BorderSizePixel = 0
								OptBtn.ZIndex = 24
								OptBtn.Parent = ListContainer

								local OptCorner = Instance.new("UICorner")
								OptCorner.CornerRadius = UDim.new(0, 4)
								OptCorner.Parent = OptBtn

								local OptPadding = Instance.new("UIPadding")
								OptPadding.PaddingLeft = UDim.new(0, 10)
								OptPadding.PaddingRight = UDim.new(0, 10)
								OptPadding.Parent = OptBtn

								local OptLabel = Instance.new("TextLabel")
								OptLabel.Size = UDim2.new(1, -18, 1, 0)
								OptLabel.BackgroundTransparency = 1
								OptLabel.Text = tostring(opt)
								OptLabel.Font = Enum.Font.Gotham
								OptLabel.TextSize = 12
								OptLabel.TextXAlignment = Enum.TextXAlignment.Left
								OptLabel.ZIndex = 25
								OptLabel.Parent = OptBtn

								local Indicator = Instance.new("Frame")
								Indicator.Size = UDim2.new(0, 12, 0, 12)
								Indicator.AnchorPoint = Vector2.new(1, 0.5)
								Indicator.Position = UDim2.new(1, 0, 0.5, 0)
								Indicator.BackgroundTransparency = 0.5
								Indicator.BorderSizePixel = 0
								Indicator.ZIndex = 25
								Indicator.Parent = OptBtn

								local IndicatorCorner = Instance.new("UICorner")
								IndicatorCorner.CornerRadius = UDim.new(0, isMulti and 3 or 6)
								IndicatorCorner.Parent = Indicator

								local IndicatorStroke = Instance.new("UIStroke")
								IndicatorStroke.Transparency = 0.72
								IndicatorStroke.Thickness = 1
								IndicatorStroke.Parent = Indicator

								local IndicatorFill = Instance.new("Frame")
								IndicatorFill.Size = UDim2.new(1, -4, 1, -4)
								IndicatorFill.Position = UDim2.new(0, 2, 0, 2)
								IndicatorFill.BackgroundTransparency = 0
								IndicatorFill.BorderSizePixel = 0
								IndicatorFill.Visible = false
								IndicatorFill.ZIndex = 26
								IndicatorFill.Parent = Indicator

								local IndicatorFillCorner = Instance.new("UICorner")
								IndicatorFillCorner.CornerRadius = UDim.new(0, isMulti and 2 or 5)
								IndicatorFillCorner.Parent = IndicatorFill

								local optionData = {
									Btn = OptBtn,
									Label = OptLabel,
									TextTheme = AddTheme(OptLabel, "TextColor3", "Muted"),
									BgTheme = AddTheme(OptBtn, "BackgroundColor3", "Inactive"),
									Indicator = Indicator,
									IndicatorTheme = AddTheme(Indicator, "BackgroundColor3", "Inactive"),
									IndicatorStroke = IndicatorStroke,
									IndicatorStrokeTheme = AddTheme(IndicatorStroke, "Color", "Border"),
									IndicatorFill = IndicatorFill,
									IndicatorFillTheme = AddTheme(IndicatorFill, "BackgroundColor3", "Accent"),
									Hovered = false
								}
							OptionButtons[opt] = optionData
							UpdateOptionButton(opt, optionData)

							TrackConnection(OptBtn.MouseEnter:Connect(function()
								optionData.Hovered = true
								UpdateOptionButton(opt, optionData)
							end))
							TrackConnection(OptBtn.MouseLeave:Connect(function()
								optionData.Hovered = false
								UpdateOptionButton(opt, optionData)
							end))

							TrackConnection(OptBtn.MouseButton1Click:Connect(function()
								if isMulti then
									if SelectedSet[opt] then
										SelectedSet[opt] = nil
									else
										SelectedSet[opt] = true
									end
									Obj.Value = CollectSelectedArray()
									SyncVisualState()
									if callback then
										callback(CopyArray(Obj.Value))
									end
								else
									Obj:SetValue(opt)
								end
							end))
						end

						SyncVisualState()
					end

					function Obj:Refresh(newOptions)
						newOptions = type(newOptions) == "table" and newOptions or {}
						local previousValue = self.Value
						BuildOptions(newOptions)

						if isMulti then
							self:SetValue(previousValue)
						elseif not table.find(newOptions, self.Value) then
							self:SetValue(newOptions[1] or "")
						else
							SyncVisualState()
						end

						if isOpened then
							local optionsHeight = #newOptions * optionHeight
							local visibleHeight = math.min(optionsHeight, dropdownMaxHeight)
							local openedHeight = 38 + visibleHeight
							TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, openedHeight)}):Play()
						end
					end

					BuildOptions(options)
					SyncVisualState()

					TrackConnection(TopBtn.MouseEnter:Connect(function()
						isHoveringTop = true
						UpdateTopVisual()
					end))
					TrackConnection(TopBtn.MouseLeave:Connect(function()
						isHoveringTop = false
						UpdateTopVisual()
					end))

					TrackConnection(TopBtn.MouseButton1Click:Connect(function()
						isOpened = not isOpened
						local optionsHeight = #options * optionHeight
						local visibleHeight = math.min(optionsHeight, dropdownMaxHeight)
						local height = isOpened and (38 + visibleHeight) or 34
						TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, height)}):Play()
						if not isOpened then
							ListContainer.CanvasPosition = Vector2.new(0, 0)
						end
						UpdateTopVisual()
					end))

					return Obj
				end

				function CardLib:AddKeybind(EConfig)
					EConfig = NormalizeElementConfig(EConfig, "Keybind")
					local text = EConfig.Title or "Keybind"
					local key = EConfig.Default or Enum.KeyCode.F
					if typeof(key) ~= "EnumItem" or key.EnumType ~= Enum.KeyCode then
						key = Enum.KeyCode.F
					end
					local flag = EConfig.Flag
					local callback = EConfig.Callback

					local binding = false
					local bindInputConnection = nil

					local KeyFrame = Instance.new("TextButton")
					KeyFrame.Size = UDim2.new(1, 0, 0, 34)
					KeyFrame.BackgroundTransparency = 1
					KeyFrame.Text = ""
					KeyFrame.AutoButtonColor = false
					KeyFrame.Parent = ItemContainer

					local Label = Instance.new("TextLabel")
					Label.Size = UDim2.new(1, -80, 1, 0)
					Label.BackgroundTransparency = 1
					Label.Text = text
					Label.Font = Enum.Font.GothamMedium
					AddTheme(Label, "TextColor3", "Muted")
					Label.TextSize = 12
					Label.TextXAlignment = Enum.TextXAlignment.Left
					Label.Parent = KeyFrame

					local BindBtn = Instance.new("TextButton")
					BindBtn.Size = UDim2.new(0, 60, 0, 22)
					BindBtn.Position = UDim2.new(1, -60, 0.5, -11)
					AddTheme(BindBtn, "BackgroundColor3", "Inactive")
					BindBtn.Text = key.Name
					BindBtn.Font = Enum.Font.GothamBold
					AddTheme(BindBtn, "TextColor3", "Text")
					BindBtn.TextSize = 11
					BindBtn.Parent = KeyFrame

					local BindCorner = Instance.new("UICorner")
					BindCorner.CornerRadius = UDim.new(0, 4)
					BindCorner.Parent = BindBtn

					local Obj = {Value = key}
					function Obj:SetValue(val)
						if typeof(val) ~= "EnumItem" or val.EnumType ~= Enum.KeyCode then
							return
						end

						self.Value = val
						BindBtn.Text = val.Name
						if callback then
							callback(val)
						end
					end

					if flag then
						Library.Flags[flag] = Obj
					end

					local function StopBinding()
						binding = false
						IsCapturingKeybind = false
						if bindInputConnection and bindInputConnection.Connected then
							bindInputConnection:Disconnect()
						end
						bindInputConnection = nil
					end

					TrackConnection(BindBtn.MouseButton1Click:Connect(function()
						binding = true
						IsCapturingKeybind = true
						BindBtn.Text = "..."

						if bindInputConnection and bindInputConnection.Connected then
							bindInputConnection:Disconnect()
						end

						bindInputConnection = UserInputService.InputBegan:Connect(function(input, gpe)
							if not binding or gpe then
								return
							end

							if input.UserInputType == Enum.UserInputType.Keyboard then
								Obj:SetValue(input.KeyCode)
							end
							StopBinding()
						end)
						TrackConnection(bindInputConnection)
					end))

					return Obj
				end

				function CardLib:AddTextbox(EConfig)
					EConfig = NormalizeElementConfig(EConfig, "Textbox")
					local text = EConfig.Title or "Textbox"
					local placeholder = EConfig.Placeholder or ""
					local flag = EConfig.Flag
					local callback = EConfig.Callback

					local TxtFrame = Instance.new("Frame")
					TxtFrame.Size = UDim2.new(1, 0, 0, 34)
					TxtFrame.BackgroundTransparency = 1
					TxtFrame.Parent = ItemContainer

					local Label = Instance.new("TextLabel")
					Label.Size = UDim2.new(0.5, 0, 1, 0)
					Label.BackgroundTransparency = 1
					Label.Text = text
					Label.Font = Enum.Font.GothamMedium
					AddTheme(Label, "TextColor3", "Muted")
					Label.TextSize = 12
					Label.TextXAlignment = Enum.TextXAlignment.Left
					Label.Parent = TxtFrame

					local InputBg = Instance.new("Frame")
					InputBg.Size = UDim2.new(0.5, 0, 0, 24)
					InputBg.Position = UDim2.new(0.5, 0, 0.5, -12)
					AddTheme(InputBg, "BackgroundColor3", "Inactive")
					InputBg.Parent = TxtFrame

					local InputCorner = Instance.new("UICorner")
					InputCorner.CornerRadius = UDim.new(0, 4)
					InputCorner.Parent = InputBg

					local IStroke = Instance.new("UIStroke")
					AddTheme(IStroke, "Color", "Border")
					IStroke.Parent = InputBg

					local Box = Instance.new("TextBox")
					Box.Size = UDim2.new(1, -10, 1, 0)
					Box.Position = UDim2.new(0, 5, 0, 0)
					Box.BackgroundTransparency = 1
					Box.Text = ""
					Box.PlaceholderText = placeholder
					Box.Font = Enum.Font.Gotham
					AddTheme(Box, "TextColor3", "Text")
					AddTheme(Box, "PlaceholderColor3", "Muted")
					Box.TextSize = 11
					Box.TextXAlignment = Enum.TextXAlignment.Right
					Box.ClearTextOnFocus = false
					Box.Parent = InputBg

					local Obj = {Value = ""}
					function Obj:SetValue(val)
						val = tostring(val or "")
						self.Value = val
						Box.Text = val
						if callback then
							callback(val)
						end
					end

					if flag then
						Library.Flags[flag] = Obj
					end

					TrackConnection(Box.FocusLost:Connect(function()
						Obj:SetValue(Box.Text)
					end))

					return Obj
				end

				-- Совместимость со старым API
				function CardLib:Button(text, callback)
					return self:AddButton({Title = text, Callback = callback})
				end

				function CardLib:Toggle(text, default, callback)
					return self:AddToggle({Title = text, Default = default, Callback = callback})
				end

				function CardLib:Slider(text, min, max, default, callback, precision)
					return self:AddSlider({
						Title = text,
						Min = min,
						Max = max,
						Default = default,
						Callback = callback,
						Precision = precision
					})
				end

					function CardLib:Dropdown(text, values, default, callback, mode)
						return self:AddDropdown({
							Title = text,
							Values = values,
							Default = default,
							Callback = callback,
							Mode = mode
						})
					end

				function CardLib:Keybind(text, default, callback)
					return self:AddKeybind({
						Title = text,
						Default = default,
						Callback = callback
					})
				end

				function CardLib:Textbox(text, placeholder, callback)
					return self:AddTextbox({
						Title = text,
						Placeholder = placeholder,
						Callback = callback
					})
				end

					return CardLib
			end

			function TabLib:Card(CConfig)
				return self:AddCard(CConfig)
			end

			return TabLib
		end

		return WindowLib
	end

return Library
