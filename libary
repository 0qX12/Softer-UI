		Library.ToggleKey = createConfig.ToggleKey
	end

	local Connections = {}
	local IsCapturingKeybind = false
	local function TrackConnection(connection)
		if connection then
			table.insert(Connections, connection)
			if #Connections % 64 == 0 then
				for i = #Connections, 1, -1 do
					local trackedConnection = Connections[i]
					if not trackedConnection or not trackedConnection.Connected then
						table.remove(Connections, i)
					end
				end
			end
		end
		return connection
	end

	local function CleanupConnections()
		for i = #Connections, 1, -1 do
			local connection = Connections[i]
			if connection and connection.Connected then
				connection:Disconnect()
			end
			Connections[i] = nil
		end
	end

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "SofterUI"
	ScreenGui.ResetOnSpawn = false
