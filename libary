				AddTheme(Label, "TextColor3", "Muted")
				Label.TextSize = 12
				Label.TextXAlignment = Enum.TextXAlignment.Left
				Label.Parent = SliderFrame

					local ValLabel = Instance.new("TextLabel")
					ValLabel.Size = UDim2.new(1, 0, 0, 20)
					ValLabel.BackgroundTransparency = 1
					ValLabel.Text = FormatValue(value)
					ValLabel.Font = Enum.Font.GothamBold
					AddTheme(ValLabel, "TextColor3", "Text")
					ValLabel.TextSize = 12
					ValLabel.TextXAlignment = Enum.TextXAlignment.Right
					ValLabel.Parent = SliderFrame

				local Track = Instance.new("TextButton")
				Track.Size = UDim2.new(1, 0, 0, 6)
				Track.Position = UDim2.new(0, 0, 0, 28)
				AddTheme(Track, "BackgroundColor3", "Inactive")
				Track.AutoButtonColor = false
				Track.Text = ""
				Track.Parent = SliderFrame
				
				local TrackCorner = Instance.new("UICorner")
					TrackCorner.CornerRadius = UDim.new(1, 0)
					TrackCorner.Parent = Track

					local Fill = Instance.new("Frame")
					local pct = (value - min) / range
					if pct ~= pct then
						pct = 0
					end
					Fill.Size = UDim2.new(pct, 0, 1, 0)
					AddTheme(Fill, "BackgroundColor3", "Accent")
					Fill.BorderSizePixel = 0
					Fill.Parent = Track
				
				local FillCorner = Instance.new("UICorner")
				FillCorner.CornerRadius = UDim.new(1, 0)
				FillCorner.Parent = Fill
				
					local Obj = {Value = value}
					function Obj:SetValue(val)
						val = tonumber(val) or min
						val = math.clamp(Quantize(val), min, max)
						if self.Value == val then
							return
						end
						self.Value = val
						ValLabel.Text = FormatValue(val)
						local newPct = (val - min) / range
						TweenService:Create(Fill, TweenInfo.new(0.1), {Size = UDim2.new(newPct, 0, 1, 0)}):Play()
						if callback then callback(val) end
					end
				
					if flag then 
						Library.Flags[flag] = Obj 
					end

					local dragging = false
					local dragChangedConnection = nil
					local dragEndedConnection = nil

					local function StopDragging()
						dragging = false
						if dragChangedConnection and dragChangedConnection.Connected then
							dragChangedConnection:Disconnect()
						end
						if dragEndedConnection and dragEndedConnection.Connected then
							dragEndedConnection:Disconnect()
						end
						dragChangedConnection = nil
						dragEndedConnection = nil
					end

					local function update(input) 
						local trackWidth = Track.AbsoluteSize.X
						if trackWidth <= 0 then
							return
						end
						local p = math.clamp((input.Position.X - Track.AbsolutePosition.X) / trackWidth, 0, 1)
						local newVal = min + (max - min) * p
						Obj:SetValue(newVal) 
					end
					
					TrackConnection(Track.InputBegan:Connect(function(input) 
						if input.UserInputType == Enum.UserInputType.MouseButton1 then 
							StopDragging()
							dragging = true
							update(input) 

							dragChangedConnection = UserInputService.InputChanged:Connect(function(changedInput)
								if dragging and changedInput.UserInputType == Enum.UserInputType.MouseMovement then
									update(changedInput)
								end
							end)
							TrackConnection(dragChangedConnection)

							dragEndedConnection = UserInputService.InputEnded:Connect(function(endedInput)
								if endedInput.UserInputType == Enum.UserInputType.MouseButton1 then
									StopDragging()
								end
							end)
							TrackConnection(dragEndedConnection)
						end 
					end))
					
					return Obj
				end

