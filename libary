local ConfigFolder = "SofterUI_configs"
local HasFileApi = type(writefile) == "function"
	and type(readfile) == "function"
	and type(listfiles) == "function"
	and type(isfile) == "function"
	and type(isfolder) == "function"
	and type(makefolder) == "function"
	and type(delfile) == "function"
local IsStudio = RunService:IsStudio() or not HasFileApi
local StudioMockFiles = {}

local function NormalizeConfigName(name)
	local normalized = tostring(name or "")
	normalized = normalized:match("^%s*(.-)%s*$") or ""
	normalized = normalized:gsub("[\\/:*?\"<>|]", "_")

	if normalized == "" then
		normalized = "Default"
	end

	return normalized
end

local function GetConfigPath(name)
	return string.format("%s/%s.txt", ConfigFolder, NormalizeConfigName(name))
end

if not IsStudio and not isfolder(ConfigFolder) then 
	makefolder(ConfigFolder) 
end

Library.GetSavedConfigs = function()
	local list = {}
	if IsStudio then
		for name, _ in pairs(StudioMockFiles) do 
			table.insert(list, name) 
		end
	else
		local ok, files = pcall(function()
			return listfiles(ConfigFolder)
		end)
		if ok and type(files) == "table" then
			for _, file in ipairs(files) do
				local name = file:match("([^/\\]+)%.txt$")
				if name then 
					table.insert(list, name) 
				end
			end
		end
	end
	if #list == 0 then 
		table.insert(list, "Default") 
	end
	table.sort(list)
	return list
end

Library.SaveConfig = function(name)
	name = NormalizeConfigName(name)
	local data = {}
	for flag, obj in pairs(Library.Flags) do
		if typeof(obj.Value) == "EnumItem" then
			data[flag] = "ENUM_" .. obj.Value.Name
		else
			data[flag] = obj.Value
		end
	end

	local success, json = pcall(function()
		return HttpService:JSONEncode(data)
	end)
	if not success then
		return false
	end

	if IsStudio then
		StudioMockFiles[name] = json
	else
		writefile(GetConfigPath(name), json)
	end

	return true
end

Library.LoadConfig = function(name)
	name = NormalizeConfigName(name)
	local json = ""
	if IsStudio then
		json = StudioMockFiles[name] or ""
	else
		local path = GetConfigPath(name)
		if isfile(path) then 
			json = readfile(path) 
		end
	end
	
	if json == "" then
		return false
	end
	
	local success, data = pcall(function() 
		return HttpService:JSONDecode(json) 
	end)
	
	if success and type(data) == "table" then
		for flag, value in pairs(data) do
			if Library.Flags[flag] then
				if type(value) == "string" and string.sub(value, 1, 5) == "ENUM_" then
					local keyName = string.sub(value, 6):match("([^:]+)$")
					local keyCode = keyName and Enum.KeyCode[keyName]
					if keyCode then
						pcall(function()
							Library.Flags[flag]:SetValue(keyCode)
						end)
					end
				else
					pcall(function() 
						Library.Flags[flag]:SetValue(value) 
					end)
				end
			end
		end
	end

	return success and type(data) == "table"
end

Library.DeleteFile = function(name)
	name = NormalizeConfigName(name)
	if IsStudio then
		StudioMockFiles[name] = nil
	else
		local path = GetConfigPath(name)
		if isfile(path) then 
			delfile(path) 
		end
	end
end

Library.DeleteConfig = Library.DeleteFile

